        "/api/v1/orders/checkout": {
            "post": {
                "tags": [
                    "Orders"
                ],
                "summary": "Passer une commande (simulation paiement)",
                "operationId": "e20deff925375d32a2cdd385c75fc65e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
